# OpenSCAD generated files
*.stl
*.off
*.amf
*.3mf
*.dxf
*.csg

# Render outputs (PNG/JPG screenshots & renders)
*.png
*.jpg
*.jpeg

# Temporary files
*.bak
*.tmp
*~
nul

# OS files
Thumbs.db
.DS_Store
desktop.ini

# Editor files
*.swp
*.swo
.vscode/
.idea/

# Build outputs
exports/
renders/

# Large binary files
*.zip
*.rar
*.7z

# Python cache (if using scripts)
__pycache__/
*.pyc

# Node modules (if using JS tools)
node_modules/

# Embedded git repos (separate repositories)
openscad-mcp/

# Keep these despite wildcards
!.gitkeep
