 --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);\r\n  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);\r\n\r\n  font-family: var(--font-sans);\r\n  font-size: 14px;\r\n  line-height: 1.5;\r\n  font-weight: 400;\r\n  color: var(--text-primary);\r\n  background-color: var(--bg-base);\r\n\r\n  font-synthesis: none;\r\n  text-rendering: optimizeLegibility;\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n}\r\n\r\nhtml, body, #root {\r\n  width: 100%;\r\n  height: 100%;\r\n  overflow: hidden;\r\n}\r\n\r\nbody {\r\n  margin: 0;\r\n  display: flex;\r\n}\r\n\r\na {\r\n  color: var(--accent-blue);\r\n  text-decoration: none;\r\n}\r\na:hover {\r\n  color: var(--accent-blue-hover);\r\n}\r\n\r\n/* Reset button defaults so our inline styles work cleanly */\r\nbutton {\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  line-height: inherit;\r\n  border: none;\r\n  background: none;\r\n  color: inherit;\r\n  cursor: pointer;\r\n  padding: 0;\r\n  border-radius: 0;\r\n}\r\nbutton:disabled {\r\n  cursor: not-allowed;\r\n}\r\n\r\ninput, select, textarea {\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  color: inherit;\r\n}\r\n\r\n/* Scrollbar styling for the dark theme */\r\n::-webkit-scrollbar {\r\n  width: 8px;\r\n  height: 8px;\r\n}\r\n::-webkit-scrollbar-track {\r\n  background: rgba(0, 0, 0, 0.2);\r\n}\r\n::-webkit-scrollbar-thumb {\r\n  background: var(--border-strong);\r\n  border-radius: 4px;\r\n  border: 1px solid rgba(0, 0, 0, 0.2);\r\n}\r\n::-webkit-scrollbar-thumb:hover {\r\n  background: #5a7ab5;\r\n}\r\n::-webkit-scrollbar-corner {\r\n  background: transparent;\r\n}\r\n\r\n/* Firefox scrollbar */\r\n* {\r\n  scrollbar-width: thin;\r\n  scrollbar-color: var(--border-strong) rgba(0, 0, 0, 0.2);\r\n}\r\n\r\n/* Selection color */\r\n::selection {\r\n  background: rgba(59, 130, 246, 0.3);\r\n  color: var(--text-primary);\r\n}\r\n\r\n/* Thinking dots animation for chat loading indicator */\r\n@keyframes thinking-ellipsis {\r\n  0% { content: ''; }\r\n  25% { content: '.'; }\r\n  50% { content: '..'; }\r\n  75% { content: '...'; }\r\n}\r\n.thinking-dots::after {\r\n  content: '';\r\n  animation: thinking-ellipsis 1.5s infinite;\r\n}\r\n\r\n/* Chat markdown overrides — keep content compact inside bubbles */\r\n.chat-markdown > :first-child { margin-top: 0; }\r\n.chat-markdown > :last-child { margin-bottom: 0; }\r\n.chat-markdown a { color: var(--accent-blue); text-decoration: underline; }\r\n.chat-markdown blockquote {\r\n  border-left: 3px solid var(--border-strong);\r\n  padding-left: 10px;\r\n  margin: 4px 0;\r\n  opacity: 0.85;\r\n}\r\n.chat-markdown hr {\r\n  border: none;\r\n  border-top: 1px solid var(--border-subtle);\r\n  margin: 6px 0;\r\n}\r\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"},["DIV",{"style":"width: 100vw; height: 100vh; display: flex; align-items: center; justify-content: center; background: var(--bg-base); overflow-y: auto;"},["DIV",{"style":"width: 100%; max-width: 560px; padding: var(--space-8); margin: auto;"},["DIV",{"style":"margin-bottom: var(--space-8);"},["H1",{"style":"font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: var(--space-2); letter-spacing: -0.02em;"},"Kinetic Forge Studio"],["P",{"style":"font-size: 14px; color: var(--text-muted); line-height: 1.6;"},"Design kinetic sculptures with methodology-enforced mechanical validation."]],["DIV",{"style":"display: flex; gap: var(--space-2); margin-bottom: var(--space-6);"},["INPUT",{"__playwright_value_":"","placeholder":"New project name...","value":"","style":"flex: 1 1 0%; padding: 10px 14px; border-radius: var(--radius-md); border: 1px solid var(--border-default); background: var(--bg-input); color: var(--text-primary); font-size: 14px; outline: none; transition: border-color 0.15s;"}],["BUTTON",{"style":"padding: 10px 20px; border-radius: var(--radius-md); background: var(--accent-blue); color: rgb(255, 255, 255); font-weight: 600; font-size: 13px; transition: background 0.15